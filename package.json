{
  "name": "m-brand-search",
  "version": "1.0.0",
  "private": true,
  "description": "Search experience and MongoDB API for the M Brand storefront",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node scripts/seedProducts.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "models:compress:one": "powershell -ExecutionPolicy Bypass -File scripts/compress-model.ps1",
    "models:compress:all": "powershell -ExecutionPolicy Bypass -File scripts/compress-model.ps1 -All"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0"
  }
}
